{
  "id": "openclaw-p2p",
  "channels": ["p2p"],
  "skills": [],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "port": {
        "type": "number",
        "default": 18790,
        "description": "WebSocket 服务端口"
      },
      "token": {
        "type": "string",
        "description": "认证 Token"
      },
      "maxImageSize": {
        "type": "number",
        "default": 10485760,
        "description": "图片最大字节数 (10MB)"
      },
      "maxFileSize": {
        "type": "number",
        "default": 52428800,
        "description": "文件最大字节数 (50MB)"
      },
      "chunkSize": {
        "type": "number",
        "default": 65536,
        "description": "分片大小 (64KB)"
      },
      "offlineCacheLimit": {
        "type": "number",
        "default": 100,
        "description": "离线消息缓存上限"
      }
    }
  },
  "channelConfigs": {
    "p2p": {
      "schema": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "认证 Token"
          },
          "enabled": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  }
}
